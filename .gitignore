# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local seed assets — raw audio/cover files used by scripts/seed-songs.mjs.
# Never commit: keeps multi-MB media (and any non-redistributable tracks) out of the public repo.
/Songs

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but keep the committed template documenting required keys
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
