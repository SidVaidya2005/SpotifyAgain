# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored; this template is committed so reviewers know what's needed.

# Supabase — Project Settings → API. Both are public (shipped to the browser);
# the anon key is safe to expose because Row Level Security protects the data.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Origin used for OAuth redirectTo (Feature 04). http://localhost:3000 locally;
# the Render URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret — server-only, never in client code. Used by the local seed script
# (`npm run seed:songs`) to write the demo catalog as the owner (bypasses RLS).
# Get it from Supabase → Project Settings → API → service_role. Leave unset for
# normal app runtime; only the seed script needs it.
# SUPABASE_SERVICE_ROLE_KEY=
# Optional — which account the seeded songs belong to (defaults to the owner email).
# SEED_USER_EMAIL=
